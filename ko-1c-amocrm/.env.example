# PostgreSQL
DATABASE_URL=postgresql+asyncpg://user:password@db:5432/ko_middleware

# amoCRM
AMO_DOMAIN=yourdomain.amocrm.ru
AMO_CLIENT_ID=
AMO_CLIENT_SECRET=
AMO_REDIRECT_URI=https://your-vps.domain/oauth/callback
AMO_REFRESH_TOKEN=

# Webhook auth (1С должна передавать этот токен в заголовке X-Auth-Token)
WEBHOOK_SECRET=changeme

# 1С (базовый URL публикации базы, напр. http://192.168.1.100/1c)
# Middleware добавляет /hs/amocrm/v1/status для обратной синхронизации
# и /hs/orders/... для pull-режима
ONEC_BASE_URL=http://192.168.1.100/1c
ONEC_USER=
ONEC_PASSWORD=
ONEC_POLL_INTERVAL_SECONDS=60

# App
DEBUG=false
LOG_LEVEL=INFO
