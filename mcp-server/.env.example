# Where to listen
PORT=3001
HOST=0.0.0.0

# Shared with the PHP backend — same as STORAGE_PATH in server/.env
# Tokens are read from `${STORAGE_PATH}/tokens/${accountId}.json`
STORAGE_PATH=/var/lib/amocrm

# AmoCRM OAuth credentials (same as PHP backend) — required for refresh
AMO_CLIENT_ID=
AMO_CLIENT_SECRET=
AMO_REDIRECT_URI=https://dist.koagency.me/oauth/callback

# Default account id used when a tool is called without `account_id` argument.
# Get it from the AmoCRM account info or from the filenames in tokens/.
DEFAULT_ACCOUNT_ID=

# Bearer token required in the Authorization header on every request.
# Generate a long random string (e.g. `openssl rand -hex 32`).
MCP_AUTH_TOKEN=

# Optional: log level (debug | info | warn | error)
LOG_LEVEL=info
