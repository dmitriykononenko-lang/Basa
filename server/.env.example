# AmoCRM OAuth credentials
AMO_CLIENT_ID=your_integration_client_id
AMO_CLIENT_SECRET=your_integration_client_secret
AMO_REDIRECT_URI=https://your-server.com/oauth/callback

# Storage path for queue state and settings (writable directory)
STORAGE_PATH=/var/www/deal-dist/storage

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# (Optional) Secret token to validate incoming requests from the widget
WIDGET_SECRET=change_me_to_a_random_string
