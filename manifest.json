{
  "widget": {
    "name": "widget.name",
    "short_description": "widget.short_description",
    "description": "widget.description",
    "version": "1.0.0",
    "interface_version": 2,
    "init_once": false,
    "locale": ["ru", "en"],
    "installation": "y",
    "support": {
      "link": "https://github.com/dmitriykononenko-lang/Basa",
      "email": "support@koagency.me"
    },
    "code": "deal_distribution",
    "secret_key": "REPLACE_WITH_SECRET_FROM_DEV_CABINET"
  },

  "oauth": "Y",

  "locations": [
    "settings",
    "advanced_settings",
    "digital_pipeline"
  ],

  "settings": {
    "server_url": {
      "name": "settings.server_url_label",
      "type": "text",
      "required": true
    },
    "distribution_method": {
      "name": "settings.method_label",
      "type": "list",
      "values": {
        "round_robin": "settings.method_round_robin",
        "workload": "settings.method_workload"
      },
      "default": "round_robin"
    }
  },

  "advanced": {},

  "dp": {
    "settings": {}
  }
}
