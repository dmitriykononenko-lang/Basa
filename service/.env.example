# --- Database ---
DB_PASSWORD=basa_dev_password

# --- Security ---
# JWT_SECRET: openssl rand -hex 32
JWT_SECRET=replace-with-32-bytes-of-randomness-please

# TOKEN_ENCRYPTION_KEY: generate via `python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"`
TOKEN_ENCRYPTION_KEY=

# --- Initial admin (создаётся при первом запуске, если ещё нет ни одного пользователя) ---
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=change-me

# --- AmoCRM OAuth ---
AMO_CLIENT_ID=
AMO_CLIENT_SECRET=
AMO_REDIRECT_URI=https://your.domain/api/v1/amo/oauth/callback
AMO_BASE_URL=https://yourdomain.amocrm.ru
